<%
	let style = '';
	let body = '';
	let script = '';
%>

<% style = `<link rel="stylesheet" type="text/css" href="/app-assets/css/plugins/forms/form-validation.css" />` %>

<% body = `<div class="content-wrapper">
				<div class="content-header row mb-2">
					<div class="content-header-left col-md-9 col-12">
						<div class="row breadcrumbs-top">
							<div class="col-12">
								<h2 class="content-header-title float-left mb-0">Parties</h2>
								<div class="breadcrumb-wrapper">
									<ol class="breadcrumb">
										<li class="breadcrumb-item">
											<a href="/">Home</a>
										</li>
										<li class="breadcrumb-item">
											<a href="/master/parties">Parties</a>
										</li>
										<li class="breadcrumb-item">` %>
										<% if (typeof(alldata) != "undefined" && alldata != null && alldata.id) { %>
											<% body += `Update Party` %>
										<% } else { %>
											<% body += `Create Party` %>
										<% } %>
										<% body += `</li>
									</ol>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="content-body">
					<section class="party-create">
						<div class="row">
							<div class="col-12">
								<div class="card">
									<div class="card-body">
										<form id="form-party-create" action="javascript:void(0);" autocomplete="off">
											<div class="row">
												<div class="form-group col-12 m-0">
													<input type="hidden" name="party-id" id="party-id" class="form-control" placeholder="Id"` %>
													<% if (typeof(alldata) != "undefined" && alldata != null && alldata.id) { %>
														<% body += ` value="` %> <% body += alldata.id %> <% body += `" readonly` %>
													<% } %>
													<% body += ` />
												</div>
												<div class="form-group col-12">
													<label class="form-label required" for="select-party-company">Company</label>
													<select class="select2 form-control form-control-lg" id="select-party-company" name="select-party-company"></select>
												</div>
												<div class="form-group col-12">
													<label class="form-label required" for="select-party-project">Project</label>
													<select class="select2 form-control form-control-lg" id="select-party-project" name="select-party-project"></select>
												</div>
												<div class="form-group col-12">
													<label class="form-label required" for="party-name">Party Name</label>
													<input type="text" name="party-name" id="party-name" class="form-control" placeholder="Enter Party Name" required />
												</div>
												<div class="form-group col-12">
													<label class="form-label" for="party-description">Party Description</label>
													<textarea name="party-description" id="party-description" class="form-control" placeholder="Enter Party Description" rows="4"></textarea>
												</div>
												<div class="form-group col-12">
													<div class="demo-inline-spacing">
														<div class="custom-control custom-control-primary custom-switch mt-0">
															<p class="mb-50 form-label" for="is-party-active">Active</p>
															<input type="checkbox" name="is-party-active" class="custom-control-input" id="is-party-active" value="1" checked /><label class="custom-control-label" for="is-party-active"></label>
														</div>
													</div>
												</div>
											</div>
											<div class="row mt-2">
												<div class="form-group col-12">
													<h4>Environment</h4>
												</div>
												<div class="form-group col-12">
													<label class="form-label" for="select-party-environment">Environment Name</label>
													<select class="select2 form-control form-control-lg" name="select-party-environment" id="select-party-environment"></select>
												</div>
												<div class="form-group col-4 col-md-2">
													<label class="form-label" for="select-domain-prefix">Domain</label>
													<select class="select2 form-control form-control-lg" name="select-domain-prefix" id="select-domain-prefix">
														<option value="http://">http://</option>
														<option value="https://">https://</option>
													</select>
												</div>
												<div class="form-group col-8 col-md-8">
													<label class="form-label invisible" for="domain">Domain</label>
													<input type="text" name="domain" id="domain" class="form-control" placeholder="Enter Domain" />
												</div>
												<div class="form-group col-12 col-md-2 text-right">
													<a href="javascript:void(0);" class="btn btn-primary mt-2" id="add-environment">Add</a>
												</div>
												<div class="col-12 mt-2">
													<table class="table table-bordered border-0" id="environment-listing">
														<thead>
															<tr>
																<th>Environment</th>
																<th>Domain</th>
																<th>Created Date</th>
																<th>Last Updated Date</th>
																<th></th>
															</tr>
														</thead>
														<tbody></tbody>
													</table>
												</div>
											</div>
											<div class="row mt-2">
												<div class="form-group col-12">
													<button class="btn btn-primary" id="create-party" type="submit">` %>
													<% if (typeof(alldata) != "undefined" && alldata != null && alldata.id) { %>
														<% body += `Update Party` %>
													<% } else { %>
														<% body += `Create Party` %>
													<% } %>
													<% body += `</button>
												</div>
											</div>
										</form>
									</div>
								</div>
							</div>
						</div>
					</section>
				</div>
			</div>` %>

<% script = `<script type="text/javascript" src="/app-assets/vendors/js/forms/validation/jquery.validate.min.js"></script>
		<script type="text/javascript" src="/assets/js/parties.js" defer></script>` %>

<%- include('layout', { title: `Party Create`, style, body, script }) %>