<%
	let style = '';
	const diffCheckerDetailModal = include('diff-history-detail-model.ejs');
	const diffCheckerLogsModal = include('diff-history-logs-view-model.ejs');
	const itemLogsViewDetailsModal = include('item-logs-view-details-modal.ejs');
	let body = '';
	let script = '';
