											<th class="header-item-name">Item Name</th>
                                            <th class="header-unique-name">Unique ID</th>
											<th class="header-path">Path</th>
											<th class="header-type">Type</th>
											<th class="header-diff-row">Total Diff. Row</th>
                                            <th class="header-created-time">Start Time</th>
										</tr>
									</thead>
									<tbody></tbody>
								</table>
								</div>
							</div>
						</div>
					</section>
				</div>
			</div>` %>
<% body += diffCheckerDetailModal; %>
<% body += diffCheckerLogsModal; %>
<% body += itemLogsViewDetailsModal; %>

<% script = `<script type="text/javascript" src="/app-assets/vendors/js/forms/validation/jquery.validate.min.js"></script>
		<script type="text/javascript" src="/app-assets/js/scripts/moment.min.js"></script>
		<script type="text/javascript" src="/app-assets/vendors/js/forms/wizard/bs-stepper.min.js"></script>
		<script type="text/javascript" src="/app-assets/vendors/js/forms/spinner/jquery.bootstrap-touchspin.js"></script>
		<script type="text/javascript" src="/app-assets/vendors/js/tables/datatable/jquery.dataTables.min.js"></script>
