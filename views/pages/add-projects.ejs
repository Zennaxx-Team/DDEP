<!-- BEGIN: Content -->
<div class="app-content content <% if (typeof(isProject) != "undefined") { %> is-project<% } %>">
	<div class="content-overlay"></div>
	<div class="header-navbar-shadow"></div>
	<div class="content-wrapper">
		<div class="content-header row">
			<div class="content-header-left col-md-9 col-12 mb-2">
				<div class="row breadcrumbs-top">
					<div class="col-12">
						<h2 class="content-header-title float-left mb-0">Items</h2>
						<div class="breadcrumb-wrapper">
							<ol class="breadcrumb">
								<li class="breadcrumb-item">
									<a href="/">Home</a>
								</li>
								<li class="breadcrumb-item">
									<a href="javascript:void(0);">Items</a>
								</li>
								<% if (typeof(alldata) != "undefined") { %>
								<li class="breadcrumb-item active">Edit Item
								<% } else if(typeof(alldata) == "undefined") { %>
								<li class="breadcrumb-item active">Add Item
								<% } %>
								</li>
							</ol>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="content-body">
			<section class="horizontal-wizard">
				<div class="bs-stepper horizontal-wizard-example">
					<div class="bs-stepper-header">
						<div class="step" data-target="#create-item" id="create-project-tab">
							<button type="button" class="step-trigger">
								<span class="bs-stepper-box">1</span>
								<span class="bs-stepper-label">
								<% if (typeof(alldata) != "undefined") { %>
								<span class="bs-stepper-title">Edit Item</span>
								<% } else { %>
								<span class="bs-stepper-title">Create New Item</span>
								<% } %>
								<span class="bs-stepper-subtitle"></span>
								</span>
							</button>
						</div>
						<div class="line">
							<i data-feather="chevron-right" class="font-medium-2"></i>
						</div>
						<div class="step" data-target="#inbound-step" id="inbound-tab">
							<button type="button" class="step-trigger">
								<span class="bs-stepper-box">2</span>
								<span class="bs-stepper-label">
								<span class="bs-stepper-title">Inbound</span>
								<span class="bs-stepper-subtitle"></span>
								</span>
							</button>
						</div>
						<div class="line">
							<i data-feather="chevron-right" class="font-medium-2"></i>
						</div>
						<div class="step" data-target="#inbound-filter-step" id="inbound-tab">
							<button type="button" class="step-trigger">
								<span class="bs-stepper-box">3</span>
								<span class="bs-stepper-label">
								<span class="bs-stepper-title">Inbound Filter</span>
								<span class="bs-stepper-subtitle"></span>
								</span>
							</button>
						</div>
						<div class="line">
							<i data-feather="chevron-right" class="font-medium-2"></i>
						</div>
						<div class="step" data-target="#outbound-step" id="outbound-tab">
							<button type="button" class="step-trigger">
								<span class="bs-stepper-box">4</span>
								<span class="bs-stepper-label">
								<span class="bs-stepper-title">Outbound</span>
								<span class="bs-stepper-subtitle"></span>
								</span>
							</button>
						</div>
						<div class="line">
							<i data-feather="chevron-right" class="font-medium-2"></i>
						</div>
						<div class="step" data-target="#mapping-step" id="mapping-tab">
							<button type="button" class="step-trigger">
								<span class="bs-stepper-box">5</span>
								<span class="bs-stepper-label">
								<span class="bs-stepper-title">Inbound Mapping</span>
								<span class="bs-stepper-subtitle"></span>
								</span>
							</button>
						</div>
						<div class="line">
							<i data-feather="chevron-right" class="font-medium-2"></i>
						</div>
						<div class="step" data-target="#outbound-filter-step" id="inbound-tab">
							<button type="button" class="step-trigger">
								<span class="bs-stepper-box">6</span>
								<span class="bs-stepper-label">
								<span class="bs-stepper-title">Outbound Filter</span>
								<span class="bs-stepper-subtitle"></span>
								</span>
							</button>
						</div>
						<div class="line">
							<i data-feather="chevron-right" class="font-medium-2"></i>
						</div>
						<div class="step" data-target="#outbound-mapping-step" id="outbound-mapping-tab">
							<button type="button" class="step-trigger">
								<span class="bs-stepper-box">7</span>
								<span class="bs-stepper-label">
								<span class="bs-stepper-title">Outbound Mapping</span>
								<span class="bs-stepper-subtitle"></span>
								</span>
							</button>
						</div>
						<div class="line">
							<i data-feather="chevron-right" class="font-medium-2"></i>
						</div>
						<div class="step" data-target="#schedule-step" id="schedule-tab">
							<button type="button" class="step-trigger">
								<span class="bs-stepper-box">8</span>
								<span class="bs-stepper-label">
								<span class="bs-stepper-title">Schedule</span>
								<span class="bs-stepper-subtitle"></span>
								</span>
							</button>
						</div>
					</div>
					<div class="bs-stepper-content">
						<div id="create-item" class="content">
							<div class="content-header">
								<% if (typeof(alldata) != "undefined") { %>
								<h5 class="mb-0">Edit Item</h5>
								<% } else { %>
								<h5 class="mb-0">Create Item</h5>
								<% } %>
								<small class="text-muted">Enter Your Item Details.</small>
							</div>
							<form id="frm-save-item" autocomplete="off">
								<div class="row">
									<% if (typeof(alldata) != "undefined") { %>
									<input type="hidden" name="Item_id" id="Item_id" value="<%= alldata._id %>" />
									<% } else { %>
									<input type="hidden" name="Item_id" id="Item_id" />
									<% } %>
									<div class="form-group col-md-4">
										<label class="form-label required" for="ItemCode">Item Code</label>
										<% if (typeof(alldata) != "undefined") { %>
										<input type="text" name="ItemCode" id="ItemCode" class="form-control" placeholder="Enter Item Code" readonly value="<%= alldata.ItemCode %>" />
										<% } else { %>
										<input type="text" name="ItemCode" id="ItemCode" class="form-control" placeholder="Enter Item Code" />
										<% } %>
									</div>
									<div class="form-group col-md-4">
										<label class="form-label required" for="ItemName">Item Name</label>
										<% if (typeof(alldata) != "undefined") { %>
										<input type="text" name="ItemName" id="ItemName" class="form-control" placeholder="Enter Item Name" aria-label="Item Code" value="<%= alldata.ItemName %>" />
										<% } else { %>
										<input type="text" name="ItemName" id="ItemName" class="form-control" placeholder="Enter Item Name" aria-label="Item Code" />
										<% } %>
									</div>
									<div class="form-group col-md-4">
										<label class="form-label required" for="CompanyName ">Company Name</label>
										<% if (typeof(alldata) != "undefined") { %>
										<input type="text" name="CompanyName" id="CompanyName" class="form-control" placeholder="Enter Company Name" aria-label="Company Name" value="<%= alldata.CompanyName %>" />
										<% } else { %>
										<input type="text" name="CompanyName" id="CompanyName" class="form-control" placeholder="Enter Company Name" aria-label="Company Name" />
										<% } %>
									</div>
								</div>
								<div class="row mt-1">
									<div class="col-12">
										<button class="btn btn-primary waves-effect" id="save_item" type="submit">Save</button>
									</div>
								</div>
							</form>
							<hr>
							<div class="d-flex justify-content-between">
