<%- include("partials/head", headerData); %>

<%- include("partials/header"); %>

<% if (typeof(companyCode) != "undefined") { %>
<script type="text/javascript">
	const dataCompanyCode = "<%= companyCode %>";
</script>
<% } else if (typeof(headerData.companyCode) != "undefined") { %>
<script type="text/javascript">
	const dataCompanyCode = "<%= headerData.companyCode %>";
</script>
<% } else { %>
<script type="text/javascript">
	const noDataCompanyCode = "companyCode not found!";
</script>
<% } %>

<!-- BEGIN: Content -->
<div class="app-content content">
	<div class="content-overlay"></div>
	<div class="header-navbar-shadow"></div>
	<div class="content-wrapper">
		<div class="content-header row">
			<div class="content-header-left col-md-9 col-12 mb-2">
				<div class="row breadcrumbs-top">
					<div class="col-12">
						<h2 class="content-header-title float-left mb-0">Notification</h2>
						<div class="breadcrumb-wrapper">
							<ol class="breadcrumb">
								<li class="breadcrumb-item">
									<a href="/">Home</a>
								</li>
								<li class="breadcrumb-item">
									<a href="javascript:void(0);">Notification</a>
								</li>
							</ol>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="content-body">
			<section class="horizontal-wizard">
				<div class="bs-stepper horizontal-wizard-example">
					<div class="bs-stepper-content">
						<div id="create-notification" class="content active dstepper-block">
							<div class="content-header">
								<% if (typeof(alldata) != "undefined" && alldata.status != 0) { %>
								<h5 class="mb-0">Edit Notification</h5>
								<% } else { %>
								<h5 class="mb-0">Create Notification</h5>
								<% } %>
								<small class="text-muted">Enter Your Notification Details.</small>
							</div>
							<form id="frm-save-notification" action="javascript:void(0);" autocomplete="off">
								<div class="row">
									<% if (typeof(alldata) != "undefined" && alldata.status != 0) { %>
									<input type="hidden" name="data_id" id="data_id" value="<%= alldata._id %>" />
									<% } else { %>
									<input type="hidden" name="data_id" id="data_id" />
									<% } %>
									<div class="form-group col-md-6">
										<label class="form-label required" for="providerName">Provider Name</label>
										<% if (typeof(alldata) != "undefined" && alldata.status != 0) { %>
										<input type="text" name="providerName" id="providerName" class="form-control" placeholder="Enter provider name" value="<%= alldata.providerName %>" required />
										<% } else { %>
										<input type="text" name="providerName" id="providerName" class="form-control" placeholder="Enter provider name" required />
										<% } %>
									</div>
									<div class="form-group col-md-6">
										<label class="form-label" for="email">Email</label>
										<% if (typeof(alldata) != "undefined" && alldata.status != 0) { %>
										<input type="text" name="email" id="email" class="form-control" placeholder="Enter email" value="<%= alldata.email %>"/>
										<% } else { %>
										<input type="text" name="email" id="email" class="form-control" placeholder="Enter email"/>
										<% } %>
										<span>(Use "," Comma to separate emails)</span>
									</div>
									<div class="form-group col-md-6">
										<label class="form-label" for="email">Email Failures Return URL</label>
										<% if (typeof(alldata) != "undefined" && alldata.status != 0) { %>
										<input type="text" name="email_failures_return_url" id="email_failures_return_url" class="form-control" placeholder="Enter Email Failures Return url" value="<%= alldata.email_failures_return_url %>"/>
										<% } else { %>
										<input type="text" name="email_failures_return_url" id="email_failures_return_url" class="form-control" placeholder="Enter Email Failures Return url"/>
										<% } %>
									</div>
									<div class="form-group col-md-6">
										<label class="form-label" for="email">Response  Failures Return URL</label>
										<% if (typeof(alldata) != "undefined" && alldata.status != 0) { %>
										<input type="text" name="response_failures_return_url" id="response_failures_return_url" class="form-control" placeholder="Enter Response  Failures Return url" value="<%= alldata.response_failures_return_url %>"/>
										<% } else { %>
										<input type="text" name="response_failures_return_url" id="response_failures_return_url" class="form-control" placeholder="Enter Response  Failures Return url"/>
										<% } %>
									</div>
									
								</div>
								<div class="row">
									<div class="form-group col-md-12">
										<h2>Which events would you like to subscribe for?</h2>
									</div>
								</div>
								<div class="row">
									<div class="form-group col-md-12">
										<h4>Inbound</h4>
									</div>
								</div>
								<div class="row">
									<div class="form-group col-md-6" style="padding: 0 45px;">
										<label class="form-label">FTP/SFTP</label>
										<div class="demo-inline-spacing">
											<div class="custom-control custom-checkbox" style="margin-top: 7px;">
												<% if (typeof(alldata) != "undefined" && alldata.status != 0 && alldata.isInboundFtpSuccess == "on") { %>
												<input type="checkbox" name="isInboundFtpSuccess" id="isInboundFtpSuccess" class="custom-control-input" aria-label="Inbound Succesful" checked />
												<% } else { %>
												<input type="checkbox" name="isInboundFtpSuccess" id="isInboundFtpSuccess" class="custom-control-input" aria-label="Inbound Succesful" />
												<% } %>
												<label class="custom-control-label" for="isInboundFtpSuccess">Inbound Succesful</label>
												<div>
													when connected to FTP and check any file required download and<br>completed download all files and converted to defined format
												</div>
											</div>
										</div>
									</div>
									<div class="form-group col-md-6" style="padding: 0 45px;">
										<label class="form-label" style="visibility: hidden;">FTP/SFTP</label>
										<div class="demo-inline-spacing">
											<div class="custom-control custom-checkbox" style="margin-top: 7px;">
												<% if (typeof(alldata) != "undefined" && alldata.status != 0 && alldata.isInboundFtpFail == "on") { %>
												<input type="checkbox" name="isInboundFtpFail" id="isInboundFtpFail" class="custom-control-input" aria-label="Inbound Fail" checked />
												<% } else { %>
												<input type="checkbox" name="isInboundFtpFail" id="isInboundFtpFail" class="custom-control-input" aria-label="Inbound Fail" />
												<% } %>
												<label class="custom-control-label" for="isInboundFtpFail">Inbound Fail</label>
												<div>
													when FTP Timeout<br>
													when downloaded Files fail<br>
													when converted defined format
												</div>
											</div>
										</div>
									</div>
									<div class="form-group col-md-6" style="padding: 0 45px;">
										<label class="form-label">DDEP API</label>
										<div class="demo-inline-spacing">
											<div class="custom-control custom-checkbox" style="margin-top: 7px;">
												<% if (typeof(alldata) != "undefined" && alldata.status != 0 && alldata.isInboundDdepApiSuccess == "on") { %>
												<input type="checkbox" name="isInboundDdepApiSuccess" id="isInboundDdepApiSuccess" class="custom-control-input" aria-label="Inbound Succesful" checked />
												<% } else { %>
												<input type="checkbox" name="isInboundDdepApiSuccess" id="isInboundDdepApiSuccess" class="custom-control-input" aria-label="Inbound Succesful" />
												<% } %>
												<label class="custom-control-label" for="isInboundDdepApiSuccess">Inbound Succesful</label>
												<div>
													when succesful posted data to DDEP API URL
												</div>
											</div>
										</div>
									</div>
									<div class="form-group col-md-6" style="padding: 0 45px;">
										<label class="form-label" style="visibility: hidden;">FTP/SFTP</label>
										<div class="demo-inline-spacing">
											<div class="custom-control custom-checkbox" style="margin-top: 7px;">
												<% if (typeof(alldata) != "undefined" && alldata.status != 0 && alldata.isInboundDdepApiFail == "on") { %>
												<input type="checkbox" name="isInboundDdepApiFail" id="isInboundDdepApiFail" class="custom-control-input" aria-label="Inbound Fail" checked />
												<% } else { %>
												<input type="checkbox" name="isInboundDdepApiFail" id="isInboundDdepApiFail" class="custom-control-input" aria-label="Inbound Fail" />
												<% } %>
												<label class="custom-control-label" for="isInboundDdepApiFail">Inbound Fail</label>
												<div>
													when connected Inbound API and HTTP Status Code not 200 or Timeout
												</div>
											</div>
										</div>
									</div>
								</div>
								<div class="row">
									<div class="form-group col-md-12">
										<h4>Outbound</h4>
									</div>
								</div>
								<div class="row">
									<div class="form-group col-md-6" style="padding: 0 45px;">
										<label class="form-label">FTP/SFTP</label>
										<div class="demo-inline-spacing">
											<div class="custom-control custom-checkbox" style="margin-top: 7px;">
												<% if (typeof(alldata) != "undefined" && alldata.status != 0 && alldata.isOutboundFtpSuccess == "on") { %>
												<input type="checkbox" name="isOutboundFtpSuccess" id="isOutboundFtpSuccess" class="custom-control-input" aria-label="Outbound Succesful" checked />
												<% } else { %>
												<input type="checkbox" name="isOutboundFtpSuccess" id="isOutboundFtpSuccess" class="custom-control-input" aria-label="Outbound Succesful" />
												<% } %>
												<label class="custom-control-label" for="isOutboundFtpSuccess">Outbound Succesful</label>
												<div>
													when connected Outbound API and HTTP Status Code = 200
												</div>
											</div>
										</div>
									</div>
									<div class="form-group col-md-6" style="padding: 0 45px;">
										<div class="demo-inline-spacing">
											<div class="custom-control custom-checkbox" style="margin-top: 7px;">
												<% if (typeof(alldata) != "undefined" && alldata.status != 0 && alldata.isOutboundFtpFail == "on") { %>
												<input type="checkbox" name="isOutboundFtpFail" id="isOutboundFtpFail" class="custom-control-input" aria-label="Outbound Fail" checked />
												<% } else { %>
												<input type="checkbox" name="isOutboundFtpFail" id="isOutboundFtpFail" class="custom-control-input" aria-label="Outbound Fail" />
												<% } %>
												<label class="custom-control-label" for="isOutboundFtpFail">Outbound Fail</label>
												<div>
													when connected Outbound API and HTTP Status Code not 200 or Timeout<br>
													when Validation Fail
												</div>
											</div>
										</div>
									</div>
									<div class="form-group col-md-6" style="padding: 0 45px;">
										<label class="form-label">DDEP API</label>
										<div class="demo-inline-spacing">
											<div class="custom-control custom-checkbox" style="margin-top: 7px;">
												<% if (typeof(alldata) != "undefined" && alldata.status != 0 && alldata.isOutboundDdepApiSuccess == "on") { %>
												<input type="checkbox" name="isOutboundDdepApiSuccess" id="isOutboundDdepApiSuccess" class="custom-control-input" aria-label="Outbound Succesful" checked />
												<% } else { %>
												<input type="checkbox" name="isOutboundDdepApiSuccess" id="isOutboundDdepApiSuccess" class="custom-control-input" aria-label="Outbound Succesful" />
												<% } %>
												<label class="custom-control-label" for="isOutboundDdepApiSuccess">Outbound Succesful</label>
												<div>
													when succesful posted data to DDEP API URL
												</div>
											</div>
										</div>
									</div>
									<div class="form-group col-md-6" style="padding: 0 45px;">
										<label class="form-label" style="visibility: hidden;">FTP/SFTP</label>
										<div class="demo-inline-spacing">
											<div class="custom-control custom-checkbox" style="margin-top: 7px;">
												<% if (typeof(alldata) != "undefined" && alldata.status != 0 && alldata.isOutboundDdepApiFail == "on") { %>
												<input type="checkbox" name="isOutboundDdepApiFail" id="isOutboundDdepApiFail" class="custom-control-input" aria-label="Outbound Fail" checked />
												<% } else { %>
												<input type="checkbox" name="isOutboundDdepApiFail" id="isOutboundDdepApiFail" class="custom-control-input" aria-label="Outbound Fail" />
												<% } %>
												<label class="custom-control-label" for="isOutboundDdepApiFail">Outbound Fail</label>
												<div>
													when connected Outbound API and HTTP Status Code not 200 or Timeout
												</div>
											</div>
										</div>
									</div>
								</div>
								<button class="btn btn-primary waves-effect mt-1" id="save_notification" type="submit">Save</button>
							</form>
						</div>
					</div>
				</div>
			</section>
		</div>
	</div>
</div>
<!-- END: Content -->

<%- include("partials/footer", footerData); %>