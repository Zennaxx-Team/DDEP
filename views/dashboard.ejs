							<div class="col-sm-12 col-md-12 col-lg-4 col-12">
								<h2 class="content-header-title float-left mb-0">Dashboard</h2>
								<div class="breadcrumb-wrapper">
									<ol class="breadcrumb">
										<li class="breadcrumb-item">
											<a href="/">Home</a>
										</li>
										<li class="breadcrumb-item">
											<a href="javascript:void(0);">Dashboard</a>
										</li>
									</ol>
								</div>
							</div>
							<div class="col-sm-12 col-md-12 col-lg-8 col-12 d-flex justify-content-end align-items-center" style="gap: 0.5rem;">
								<!-- Log Description Input -->
								<div style="flex: 1 1 auto; min-width: 220px; max-width: 220px;">
									<input type="text" 
										class="form-control" 
										id="dashboard-log-description" 
										name="dashboard-log-description" 
										placeholder="Log Description">
								</div>
								<div class="d-flex justify-content-center align-items-center"
									style="width: 36px; height: 36px; border: 1px solid #ccc; border-radius: 4px; cursor: pointer; background-color: #fff;">
									<i data-feather="search" id="dashboard-log-search-btn"></i>
								</div>
								<div style="flex: 1 1 auto; min-width: 0; max-width: 220px;">
									<select class="select2 form-control form-control-sm w-100" 
										id="select-dashboard-item" 
										name="select-dashboard-item">
									</select>
								</div>
								<div style="flex: 0 0 220px; min-width: 220px;">
									<div id="dashboardreportrange" 
										style="background: #fff; cursor: pointer; padding: 6px 10px; border: 1px solid #ccc; width: 100%; border-radius: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
										<i data-feather="clock"></i>&nbsp;<span></span>
									</div>
									<div class="hidden since-time-dashboard"></div>
								</div>
							</div>
						</div>
					</div>
				</div>
				<div class="content-body">
					<section class="">
						<div class="row match-height">
                            <div class="col-12 col-sm-6 col-md-4">
                                <div class="card">
                                    <div class="card-header d-flex flex-sm-row flex-column justify-content-md-between align-items-start justify-content-start">
                                        <div>
                                            <h4 class="card-title mb-25">Throughput</h4>
                                            <small class="card-sub-title">30 mins = 5 minutes</small>
                                        </div>
                                    </div>
                                    <div class="card-body">
                                        <div id="line-chart-1" style="max-height: 250px;"></div>
                                    </div>
                                </div>
							</div>
                            <div class="col-12 col-sm-6 col-md-4">
