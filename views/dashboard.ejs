											<li class="nav-item">
												<a class="nav-link active" id="transactions-tab-fill" data-toggle="tab" href="#transactions-fill" role="tab" aria-controls="transactions-fill" aria-selected="true">Transactions</a>
											</li>
											<li class="nav-item">
												<a class="nav-link" id="slowest-tab-fill" data-toggle="tab" href="#slowest-fill" role="tab" aria-controls="slowest-fill" aria-selected="false">Top 10 Slowest</a>
											</li>
											<li class="nav-item">
												<a class="nav-link" id="exceptions-tab-fill" data-toggle="tab" href="#exceptions-fill" role="tab" aria-controls="exceptions-fill" aria-selected="false">Exceptions</a>
											</li>
										</ul>
										<div class="tab-content pt-1">
											<div class="tab-pane active" id="transactions-fill" role="tabpanel" aria-labelledby="transactions-tab-fill">
												<div class="table-responsive">
													<table class="table table-bg-color transactions-table">
														<thead>
															<tr>
																<th class="home-table-01">No</th>
																<th class="home-table-02">Item Name</th>
																<th class="home-table-03">Path</th>
																<th class="home-table-04">Log Description</th>
																<th class="home-table-05">HTTP Status</th>
																<th class="home-table-06">Start Time</th>
																<th class="home-table-07">Time Consumed (MS)</th>
															</tr>
														</thead>
														<tbody></tbody>
													</table>
												</div>
											</div>
											<div class="tab-pane" id="slowest-fill" role="tabpanel" aria-labelledby="slowest-tab-fill">
												<div class="table-responsive">
													<table class="table table-bg-color slowest-table">
														<thead>
															<tr>
																<th>No</th>
																<th>Item Name</th>
																<th>Path</th>
																<th>Log Description</th>
																<th>HTTP Status</th>
																<th>Start Time</th>
																<th>Time Consumed (MS)</th>
															</tr>
														</thead>
														<tbody></tbody>
													</table>
												</div>
											</div>
											<div class="tab-pane" id="exceptions-fill" role="tabpanel" aria-labelledby="exceptions-tab-fill">
												<div class="table-responsive">
													<table class="table table-bg-color exceptions-table">
														<thead>
															<tr>
																<th>No</th>
																<th>Item Name</th>
																<th>Type</th>
																<th>Path</th>
																<th>Details Desscription</th>
																<th>Start Time</th>
															</tr>
														</thead>
														<tbody></tbody>
													</table>
												</div>
											</div>
										</div>
									</div>
								</div>
							</div>
						</div>
					</section>
				</div>
